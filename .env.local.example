# AI API Keys
# DeepSeek / OpenCode AI — used for quiz analysis + recommendations + TCM food analysis
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Qwen-VL (Dashscope) — used for food image recognition in Food Scan
QWEN_API_KEY=your_dashscope_qwen_api_key_here

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@ep-xxx.region.neon.tech/neondb?sslmode=require
DIRECT_URL=postgresql://user:password@ep-xxx.region.neon.tech/neondb?sslmode=require

# NextAuth (for Vercel deployment)
AUTH_URL=https://your-domain.com
AUTH_SECRET=your_auth_secret_here
